rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        (request.auth.token.email in get(/databases/$(database)/documents/admin_config/allowed).data.emails);
    }

    // Optional: validate common fields on media documents
    function validMediaSchema() {
      return
        (request.resource.data.keys().hasOnly([
          'id','filename','basename','ext','mime','size','url','alt',
          'createdAt','updatedAt','folderId','starred','lastAccessed',
          'width','height','tags','createdBy','variants','attachedTo'
        ])) &&
        (request.resource.data.createdAt is int) &&
        (request.resource.data.updatedAt is int) &&
        (request.resource.data.size is int) &&
        (request.resource.data.mime is string) &&
        (request.resource.data.url is string) &&
        (request.resource.data.folderId is string) &&
        (request.resource.data.starred is bool);
    }

    // --- Media library ---
    match /media/{id} {
      // Admin-only read/list
      allow get, list, read: if isAdmin();

      // Admin-only writes with basic schema checks
      allow create, update, delete: if isAdmin()
        && (
          // allow partial updates but enforce core fields when present
          (!('createdAt' in request.resource.data) || request.resource.data.createdAt is int) &&
          (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is int)
        );

      // Notes:
      // - Queries like folder filtering or favorites are permitted for admins:
      //   e.g., where("folderId", "==", "..."), where("starred", "==", true)
      // - Create the needed composite indexes in Firestore as prompted by the console.
    }

    // --- Folders/Collections metadata ---
    match /folders/{id} {
      allow get, list, read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // --- Audit logs: append-only for admins ---
    match /audit_logs/{id} {
      allow create: if isAdmin();
      allow read, list: if isAdmin();
      allow update, delete: if false; // immutable once written
    }

    // --- Admin config: readable by admins only ---
    match /admin_config/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
